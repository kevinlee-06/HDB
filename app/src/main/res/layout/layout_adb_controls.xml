<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permission hint -->
    <TextView
        android:id="@+id/card_perm_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:text="@string/perm_grant_hint"
        android:textColor="#B71C1C"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/card_title_immediate"
        android:textAppearance="?android:attr/textAppearanceMedium"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/radio_group_immediate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/radio_imm_0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/option_0"
            android:minHeight="56dp"
            android:gravity="center_vertical"
            android:textSize="16sp"
            android:tag="0" />

        <RadioButton
            android:id="@+id/radio_imm_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/option_1"
            android:minHeight="56dp"
            android:gravity="center_vertical"
            android:textSize="16sp"
            android:tag="1" />

        <RadioButton
            android:id="@+id/radio_imm_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/option_2"
            android:minHeight="56dp"
            android:gravity="center_vertical"
            android:textSize="16sp"
            android:tag="2" />
    </RadioGroup>

</merge>
